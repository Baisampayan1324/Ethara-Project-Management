generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum Status {
  TODO
  IN_PROGRESS
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectType {
  MEETING_INTELLIGENCE
  LEAD_AUTOMATION
  RAG_KNOWLEDGE
  EMAIL_AUTOMATION
  EMAIL_TRIAGE
  RESEARCH_ASSISTANT
  NL2SQL_ANALYTICS
  ALGO_TRADING
  EDTECH_PLATFORM
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          Role      @default(MEMBER)
  createdAt     DateTime  @default(now())
  
  projects      Project[] @relation("ProjectCreator")
  assignedTasks Task[]    @relation("TaskAssignee")
  memberOf      Project[] @relation("ProjectMembers")
  ledTeams      Team[]    @relation("TeamLead")
  team          Team?     @relation("TeamUsers", fields: [teamId], references: [id], onDelete: SetNull)
  teamId        String?
}

model Team {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())

  lead        User?     @relation("TeamLead", fields: [leadId], references: [id])
  leadId      String?

  members     User[]    @relation("TeamUsers")
  projects    Project[]
}

model Project {
  id          String    @id @default(uuid())
  type        ProjectType @default(RAG_KNOWLEDGE)
  name        String
  description String?
  deadline    DateTime?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  
  createdBy   User      @relation("ProjectCreator", fields: [createdById], references: [id])
  createdById String

  team        Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamId      String?
  
  members     User[]    @relation("ProjectMembers")
  tasks       Task[]
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      Status    @default(TODO)
  priority    Priority  @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  
  assignedTo  User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId  String?
}
